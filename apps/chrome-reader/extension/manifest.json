{
  "manifest_version": 3,
  "name": "Chrome Reader - Kokoro TTS",
  "version": "1.0.0",
  "description": "Read any webpage aloud with Kokoro TTS. Smart content extraction, word-level highlighting, and multiple voices.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8008/*",
    "http://127.0.0.1:8008/*",
    "http://*:8008/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["extractor.js", "highlighter.js", "player.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-reading": {
      "suggested_key": { "default": "Alt+R" },
      "description": "Play or pause reading"
    },
    "stop-reading": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Stop reading"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
